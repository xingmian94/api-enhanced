{
  "version": 2,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.js",
      "headers": {
        "Access-Control-Allow-Credentials": "true",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Type"
      }
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "ENABLE_FLAC": "true"
  },
  "installCommand": "npm install"
}
